                    "props": {
                      "href": "/visit",
                      "className": "gallery-button-ghost"
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "basic",
            "name": "Section",
            "props": {
              "className": "gallery-stack"
            },
            "children": [
              {
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "gallery-section-heading"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Span",
                    "text": "$t:home.news.section_kicker",
                    "props": {
                      "className": "gallery-kicker"
                    }
                  },
                  {
                    "type": "basic",
                    "name": "H2",
                    "text": "$t:home.news.section_title",
                    "props": {
                      "className": "gallery-title-lg"
                    }
                  }
                ]
              },
              {
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "gallery-card-grid"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Div",
                    "iteration": {
                      "source": "{{latest_news.data ?? []}}",
                      "item_var": "item"
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "Div",
                        "props": {
                          "className": "gallery-card gallery-empty-card"
                        },
                        "children": [
                          {
                            "type": "basic",
                            "name": "Span",
                            "text": "{{item.date ?? item.created_at_formatted ?? item.created_at ?? ''}}",
                            "props": {
                              "className": "gallery-meta"
                            }
                          },
                          {
                            "type": "basic",
                            "name": "H3",
                            "text": "{{item.title ?? $t:pages.fallback_title}}",
                            "props": {
                              "className": "gallery-title-md"
                            }
                          },
                          {
                            "type": "basic",
                            "name": "P",
                            "text": "{{item.summary ?? item.board_name ?? item.author_name ?? $t:pages.fallback_description}}",
                            "props": {
                              "className": "gallery-body"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "basic",
            "name": "Section",
            "props": {
              "className": "gallery-surface gallery-hero"
            },
            "children": [
              {
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "gallery-hero-copy"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Span",
                    "text": "$t:home.cta.section_kicker",
                    "props": {
                      "className": "gallery-kicker"
                    }
                  },
                  {
                    "type": "basic",
                    "name": "H2",
                    "text": "$t:home.cta.section_title",
                    "props": {
                      "className": "gallery-title-lg"
                    }
                  },
                  {
                    "type": "basic",
                    "name": "P",
                    "text": "$t:home.cta.description",
                    "props": {
                      "className": "gallery-body-lg"
                    }
                  },
                  {
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "gallery-actions"
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "A",
                        "text": "$t:home.cta.visit_cta",
                        "props": {
                          "href": "/visit",
                          "className": "gallery-button"
                        }
                      },
                      {
                        "type": "basic",
                        "name": "A",
                        "text": "$t:home.cta.contact_cta",
                        "props": {
                          "href": "/contact",
                          "className": "gallery-button-ghost"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
