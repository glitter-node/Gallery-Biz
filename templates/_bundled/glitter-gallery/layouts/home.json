{
  "version": "1.0.0",
  "layout_name": "home",
  "permissions": [],
  "extends": "_user_base",
  "meta": {
    "title": "$t:nav.home",
    "seo": {
      "enabled": true,
      "data_sources": [
        "latest_news"
      ],
      "priority": 1,
      "changefreq": "daily",
      "og": {
        "type": "website"
      }
    }
  },
  "data_sources": [
    {
      "id": "latest_news",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-board/boards/posts/recent?limit=3",
      "method": "GET",
      "auto_fetch": true,
      "loading_strategy": "progressive",
      "errorHandling": {
        "fallback": {
          "data": []
        }
      },
      "fallback": {
        "data": [
          {
            "date": "2026-04-18",
            "title": "오프닝 리셉션 안내",
            "summary": "새 시즌 전시 오프닝 일정과 현장 운영 정보를 먼저 확인할 수 있도록 핵심 공지를 요약했습니다."
          },
          {
            "date": "2026-04-12",
            "title": "도슨트 프로그램 예약 오픈",
            "summary": "주말 관람객을 위한 도슨트 프로그램 예약이 시작되었습니다. 방문 전 시간대와 인원 제한을 확인해 주세요."
          },
          {
            "date": "2026-04-05",
            "title": "공간 점검에 따른 운영 시간 조정",
            "summary": "공간 점검으로 일부 날짜의 운영 시간이 변경됩니다. 헛걸음을 줄이기 위해 변경 일정을 함께 안내합니다."
          }
        ]
      }
    }
  ],
